<Window x:Class="Snake.Views.ExitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="400" Height="150">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/DialogStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Style="{StaticResource ExitContainerGridStyle}">

        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
            Text="Do you want to exit the game?" 
            Style="{StaticResource ExitMessageTextBlockStyle}"/>

        <StackPanel Grid.Row="1" Style="{StaticResource ExitButtonContainerStackPanelStyle}">
            <Button Content="Yes" IsDefault="True" Style="{StaticResource ExitYesButtonStyle}" Click="YesButton_Click"/>
            <Button Content="No" IsCancel="True" Style="{StaticResource ExitNoButtonStyle}" Click="NoButton_Click"/>
        </StackPanel>

    </Grid>
</Window>