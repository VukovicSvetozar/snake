<Window x:Class="Snake.Views.LeaderboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        SizeChanged="Window_SizeChanged"
        WindowStartupLocation="CenterScreen"
        Height="820" Width="1100" MinHeight="549" MinWidth="800">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/LeaderboardStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Style="{StaticResource ContainerGridStyle}">

        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="16*" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <TextBlock Text="Leaderboard" Style="{StaticResource HeaderTextBlockStyle}" />
        </Border>

        <Border Grid.Row="1" Style="{StaticResource LeaderboardBorderStyle}">
            <ListView x:Name="LeaderboardListView" ItemsSource="{Binding Players}" Style="{StaticResource LeaderboardListViewStyle}" ItemContainerStyle="{StaticResource LeaderboardListViewItemStyle}">
                <ListView.View>
                    <GridView>

                        <GridView.ColumnHeaderContainerStyle>
                            <StaticResource ResourceKey="LeaderboardHeaderGridViewStyle" />
                        </GridView.ColumnHeaderContainerStyle>

                        <GridViewColumn Header="Rank">
                            <GridViewColumn.CellTemplate>
                                <StaticResource ResourceKey="LeaderboardRankColumnTemplate" />
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Name">
                            <GridViewColumn.CellTemplate>
                                <StaticResource ResourceKey="LeaderboardNameColumnTemplate" />
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Points">
                            <GridViewColumn.CellTemplate>
                                <StaticResource ResourceKey="LeaderboardPointsColumnTemplate" />
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <StackPanel Grid.Row="2" Style="{StaticResource FooterStackPanelStyle}">
            <Button Content="OK" IsDefault="True" Style="{StaticResource FooterOkButtonStyle}" Click="OkButton_Click"/>
        </StackPanel>

    </Grid>

</Window>