<Window x:Class="Snake.Views.NameInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Snake.Views"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Width="400" Height="250">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/DialogStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Style="{StaticResource ExitContainerGridStyle}">

        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
            Text="Congratulations!" 
            Style="{StaticResource NameInputMessageTextBlockStyle}"/>

        <TextBox Grid.Row="1" x:Name="NameTextBox" 
            TextChanged="NameInput_TextChanged"     
            Style="{StaticResource NameInputTextBoxStyle}"/>
        <TextBlock Grid.Row="1" Name="TxtPlaceholder" 
            Text="Enter your name"
            Style="{StaticResource NameInputTextBlockStyle}"/>
        <Popup x:Name="NameMissingPopup" 
               PlacementTarget="{Binding ElementName=NameTextBox}" Style="{StaticResource NameInputPopupStyle}">
            <Border Style="{StaticResource NameInputPopupBorderStyle}">
                <TextBlock Text="Please enter a name." Style="{StaticResource NameInputPopupTextBlockStyle}"/>
            </Border>
        </Popup>

        <Button Grid.Row="2" Content="OK" IsDefault="True" 
            Click="OkButton_Click"
            Style="{StaticResource NameInputButtonStyle}"/>

    </Grid>

</Window>