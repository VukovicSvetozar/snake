<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="ContainerGridStyle" TargetType="Grid">
        <Setter Property="Background" Value="LightGreen"/>
    </Style>

    <Style x:Key="LeftPanelBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="20 20 10 20"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="BorderBrush" Value="Teal"/>
        <Setter Property="Background" Value="#C8FFC3"/>
    </Style>

    <Style x:Key="LeftPanelGridStyle" TargetType="Grid">
        <Setter Property="Margin" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Teal"/>
    </Style>

    <Style x:Key="LeftPanelImageStyle" TargetType="Image">
        <Setter Property="Height" Value="150"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="70"/>
        <Setter Property="Margin" Value="20 0 20 20"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="Teal"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border 
                        Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="4" CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StartGameButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="MediumAquamarine"/>
        <Setter Property="BorderBrush" Value="LightSeaGreen"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="LightGreen"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SettingsButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#42D082"/>
        <Setter Property="BorderBrush" Value="LightSeaGreen"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="LightGreen"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LeaderboardButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#42D082"/>
        <Setter Property="BorderBrush" Value="LightSeaGreen"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="LightGreen"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ExitButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="MediumAquamarine"/>
        <Setter Property="BorderBrush" Value="LightSeaGreen"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="LightGreen"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MenuButtonToolTipStyle" TargetType="ToolTip">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border 
                        Background="#C8FFC3" 
                        BorderBrush="DimGray" 
                        BorderThickness="2" 
                        CornerRadius="10" 
                        Padding="7">
                        <TextBlock Text="{TemplateBinding Content}" 
                           TextWrapping="Wrap" 
                           Foreground="DarkSlateGray" 
                           FontSize="14"
                           FontWeight="SemiBold"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style x:Key="GameAreaBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="10 20 10 20"/>
        <Setter Property="Cursor" Value="None"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="BorderBrush" Value="Teal"/>
        <Setter Property="BorderThickness" Value="20"/>
        <Setter Property="Background" Value="#C8FFC3"/>
    </Style>

    <Style x:Key="RightPanelBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="20 20 10 20"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="BorderBrush" Value="Teal"/>
        <Setter Property="Background" Value="#C8FFC3"/>
    </Style>

    <Style x:Key="RightPanelGridStyle" TargetType="Grid">
        <Setter Property="Margin" Value="20"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Teal"/>
    </Style>

    <Style x:Key="InfoLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="LightGreen"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="InfoBorderStyle" TargetType="Border">
        <Setter Property="MaxHeight" Value="80"/>
        <Setter Property="Margin" Value="25 5 20 15"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Background" Value="#C8FFC3"/>
        <Setter Property="BorderBrush" Value="LightGreen"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="InfoTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="Teal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="InfoPauseLabelStyle" TargetType="Label">
        <Setter Property="Margin" Value="0 15 0 0"/>
        <Setter Property="FontSize" Value="25"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="LightGreen"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>