<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="ContainerGridStyle" TargetType="Grid">
        <Setter Property="Background" Value="LightGreen"/>
    </Style>

    <Style x:Key="HeaderBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="0 5 0 0"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="Teal"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="2.2" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Teal" ShadowDepth="3" BlurRadius="10" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LeaderboardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="#C8FFC3"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="17 0 17 0"/>
        <Setter Property="Margin" Value="25 5 25 5"/>
    </Style>

    <Style x:Key="LeaderboardListViewStyle" TargetType="ListView">
        <Setter Property="Background" Value="#C8FFC3"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="20 30 20 0"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style x:Key="LeaderboardListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="Background" Value="#C8FFC3"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border 
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <GridViewRowPresenter Content="{TemplateBinding Content}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LeaderboardHeaderGridViewStyle" TargetType="GridViewColumnHeader">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="Margin" Value="0 0 0 20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="MintCream"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border Background="MediumSeaGreen" CornerRadius="5" Padding="8" Margin="2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="LeaderboardRankColumnTemplate">
        <Border Background="LightGreen" BorderBrush="Teal" BorderThickness="2"
                CornerRadius="12" Padding="5" Margin="0 0 0 8">
            <Border Background="LightGreen" 
                    CornerRadius="12" Padding="3" 
                    ClipToBounds="True">
                <TextBlock Text="{Binding Rank, StringFormat='{}{0}.'}"  
                    Background="#C8FFC3" Foreground="Teal" Width="200"
                    FontSize="20" FontWeight="Bold" FontStyle="Italic" 
                    HorizontalAlignment="Center" TextAlignment="Center"/>
            </Border>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="LeaderboardNameColumnTemplate">
        <Border Background="MediumSeaGreen" BorderBrush="Teal" BorderThickness="2" 
                CornerRadius="12" Padding="5" Margin="0 0 0 8">
            <Border Background="LightGreen" 
                    CornerRadius="12" Padding="3" 
                    ClipToBounds="True">
                <TextBlock Text="{Binding Name}" 
                    Foreground="Teal" Width="1000"
                    FontSize="20" FontWeight="Bold" FontStyle="Italic" 
                    HorizontalAlignment="Center" TextAlignment="Center"/>
            </Border>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="LeaderboardPointsColumnTemplate">
        <Border BorderBrush="Teal" BorderThickness="2" 
                CornerRadius="12" Padding="5" Margin="0 0 0 8">
            <Border Background="Teal" 
                    CornerRadius="12" Padding="3" 
                    ClipToBounds="True">
                <TextBlock Text="{Binding Points}" 
                    Foreground="#C8FFC3" Width="200"
                    FontSize="20" FontWeight="Bold" FontStyle="Italic" 
                    HorizontalAlignment="Center" TextAlignment="Center"/>
            </Border>
        </Border>
    </DataTemplate>

    <Style x:Key="FooterStackPanelStyle" TargetType="StackPanel">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0 0 0 10"/>
    </Style>

    <Style x:Key="FooterOkButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="120"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="Honeydew"/>
        <Setter Property="Background" Value="Teal"/>
        <Setter Property="BorderBrush" Value="DarkGreen"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="SeaGreen" ShadowDepth="3" BlurRadius="5" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border 
                        Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="2" CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#009696"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>